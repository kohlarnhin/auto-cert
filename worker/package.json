{
  "name": "auto-cert-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/write-wrangler-config.mjs && wrangler dev --config wrangler.toml",
    "deploy": "node scripts/write-wrangler-config.mjs && wrangler deploy --config wrangler.toml --secrets-file .wrangler/generated-secrets.json",
    "upload": "node scripts/write-wrangler-config.mjs && wrangler versions upload --config wrangler.toml --secrets-file .wrangler/generated-secrets.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
