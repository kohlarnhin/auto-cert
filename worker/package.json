{
  "name": "auto-cert-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "prepare:cloudflare": "node scripts/prepare-cloudflare-deploy.mjs",
